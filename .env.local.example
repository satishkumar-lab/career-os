# Supabase — find these in Supabase Dashboard → Settings → API
#
# Required for all environments (local + Vercel):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
#
# Optional server-only fallbacks (same values as above):
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
#
# On Vercel: add NEXT_PUBLIC_* vars, then trigger a new deployment so
# client bundles receive the values at build time.
