# Supabase — Supabase Dashboard → Settings → API
#
# PROJECT URL (required — NOT the REST endpoint):
#   ✅ https://your-project-ref.supabase.co
#   ❌ https://your-project-ref.supabase.co/rest/v1
#
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to the browser (Supabase Dashboard → Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# Canonical app URL — used for OAuth redirect_uri (local + production)
# Local: http://localhost:3000
# Production: https://career-os-rho-red.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# LinkedIn Developer Portal → App → Auth tab
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Optional — HMAC secret for LinkedIn OAuth state cookie (defaults to LINKEDIN_CLIENT_SECRET)
# LINKEDIN_OAUTH_STATE_SECRET=
